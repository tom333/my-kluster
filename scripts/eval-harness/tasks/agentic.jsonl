{"id": "multi_lookup_calc", "system": "You are an assistant with tools. Call tools to gather facts, then reply with the final numeric answer.", "user": "What is the total cost of 3 widgets and 2 gadgets? Use the tools to look up unit prices.", "tools": [{"type": "function", "function": {"name": "get_price", "description": "Unit price of an item", "parameters": {"type": "object", "properties": {"item": {"type": "string"}}, "required": ["item"]}}}, {"type": "function", "function": {"name": "calc", "description": "Evaluate an arithmetic expression", "parameters": {"type": "object", "properties": {"expression": {"type": "string"}}, "required": ["expression"]}}}], "mock": {"get_price": {"widget": "10", "gadget": "25"}, "calc": "__eval__"}, "expect": {"type": "numeric", "value": 80}, "max_turns": 6}
{"id": "sequential_dependency", "system": "You are an assistant with tools. Chain calls as needed, then give the final numeric answer.", "user": "How many orders does user 42 have? First resolve the user id to a name, then look up that user's order count.", "tools": [{"type": "function", "function": {"name": "get_user", "description": "Resolve a user id to a username", "parameters": {"type": "object", "properties": {"id": {"type": "string"}}, "required": ["id"]}}}, {"type": "function", "function": {"name": "get_orders", "description": "Number of orders for a username", "parameters": {"type": "object", "properties": {"name": {"type": "string"}}, "required": ["name"]}}}], "mock": {"get_user": {"42": "alice"}, "get_orders": {"alice": "3"}}, "expect": {"type": "numeric", "value": 3}, "max_turns": 6}
{"id": "search_then_read", "system": "You are an assistant with tools. Locate then inspect files, then answer.", "user": "What port does the app config use? Find the config file by keyword then read it.", "tools": [{"type": "function", "function": {"name": "find_file", "description": "Find a file path by keyword", "parameters": {"type": "object", "properties": {"keyword": {"type": "string"}}, "required": ["keyword"]}}}, {"type": "function", "function": {"name": "read_file", "description": "Read a file's contents", "parameters": {"type": "object", "properties": {"path": {"type": "string"}}, "required": ["path"]}}}], "mock": {"find_file": {"config": "app.conf"}, "read_file": {"app.conf": "port=8080\nhost=localhost"}}, "expect": {"type": "contains", "value": "8080"}, "max_turns": 6}
{"id": "check_then_act", "system": "You are an ops assistant with tools. Take corrective action if needed, then report the final status.", "user": "Check if the nginx service is running. If it is down, restart it. Then tell me its final status.", "tools": [{"type": "function", "function": {"name": "check_status", "description": "Current status of a service", "parameters": {"type": "object", "properties": {"service": {"type": "string"}}, "required": ["service"]}}}, {"type": "function", "function": {"name": "restart", "description": "Restart a service", "parameters": {"type": "object", "properties": {"service": {"type": "string"}}, "required": ["service"]}}}], "mock": {"check_status": {"nginx": "down"}, "restart": {"nginx": "restarted, now running"}}, "expect": {"type": "contains", "value": "running"}, "max_turns": 6}
{"id": "compare_two", "system": "You are an assistant with tools. Gather both facts before concluding.", "user": "Is it warmer in Paris or Lyon right now? Check both cities and name the warmer one.", "tools": [{"type": "function", "function": {"name": "get_weather", "description": "Current temperature of a city", "parameters": {"type": "object", "properties": {"city": {"type": "string"}}, "required": ["city"]}}}], "mock": {"get_weather": {"Paris": "15C", "Lyon": "20C"}}, "expect": {"type": "contains", "value": "Lyon"}, "max_turns": 6}
{"id": "three_step_chain", "system": "You are an assistant with tools. Multi-step reasoning over tool results is expected.", "user": "Among the current users, find the one with the most points, then look up that user's email. Reply with the email address.", "tools": [{"type": "function", "function": {"name": "list_users", "description": "List all usernames", "parameters": {"type": "object", "properties": {}}}}, {"type": "function", "function": {"name": "get_points", "description": "Points for a username", "parameters": {"type": "object", "properties": {"name": {"type": "string"}}, "required": ["name"]}}}, {"type": "function", "function": {"name": "get_email", "description": "Email for a username", "parameters": {"type": "object", "properties": {"name": {"type": "string"}}, "required": ["name"]}}}], "mock": {"list_users": {"*": "alice, bob"}, "get_points": {"alice": "50", "bob": "90"}, "get_email": {"bob": "bob@example.com"}}, "expect": {"type": "contains", "value": "bob@example.com"}, "max_turns": 8}
