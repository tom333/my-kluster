# Managed by Ansible — do not edit by hand.
# Consumed by docker-compose via `env_file: .env`. Every value substitutes
# into the docker-compose.yml template at container start.

LVA_IMAGE={{ lva_image }}
LVA_IMAGE_TAG={{ lva_image_tag }}

# UID/GID inside the container — must equal the host user that owns the
# PulseAudio socket bound below. Mismatch = permission denied on the socket.
LVA_USER_ID={{ lva_user_id }}
LVA_USER_GROUP={{ lva_user_group }}

# Friendly name surfaced to HA via the ESPHome API.
CLIENT_NAME={{ lva_client_name }}

# PulseAudio / PipeWire-pulse socket bridging.
LVA_PULSE_SERVER={{ lva_pulse_server }}
LVA_XDG_RUNTIME_DIR={{ lva_xdg_runtime_dir }}
LVA_PULSE_COOKIE={{ lva_pulse_cookie }}

# Active wake-word model from /app/wakewords/ (shipped with the image).
WAKE_MODEL={{ lva_wake_model }}

# ESPHome native API port — HA's ESPHome integration connects here.
PORT={{ lva_port }}
